<UserControl x:Class="WpfIveco.Views.PecasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <DropShadowEffect x:Key="DropShadowEffect" BlurRadius="12" ShadowDepth="2" Opacity="0.12" Color="Black"/>

        <Style x:Key="PremiumComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="{StaticResource ElevatedGray3}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI, sans-serif"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" Text="&#xE74C;" FontSize="16" 
                                               Foreground="{StaticResource TextSecondary}" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>

                                    <ContentPresenter x:Name="ContentPresenter" Grid.Column="1" 
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="8,0,12,0" VerticalAlignment="Center" IsHitTestVisible="False"/>

                                    <ToggleButton x:Name="PART_DropDownToggle" Grid.Column="2" Focusable="False" ClickMode="Press"
                                                  Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" Margin="0,0,14,0"
                                                  VerticalAlignment="Center" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                        <Path Fill="{StaticResource TextSecondary}" Data="M0,0 L5,5 L10,0 Z" Width="12" Height="7" Stretch="Fill"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                   MaxHeight="250" AllowsTransparency="True" StaysOpen="False">
                                <Border Background="White" CornerRadius="12" BorderBrush="{StaticResource ElevatedGray3}" BorderThickness="1"
                                        Margin="0,6,0,0" Padding="6" Effect="{StaticResource DropShadowEffect}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AppleBlue}"/>
                                <Setter TargetName="Border" Property="Background" Value="#F8FAFF"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AppleBlue}"/>
                                <Setter TargetName="Border" Property="Background" Value="#F0F8FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource ElevatedGray2}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource ElevatedGray3}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Padding" Value="14,10"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" Text="&#xE74C;" FontSize="14" 
                                                       Foreground="{StaticResource AppleBlue}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter Property="Background" Value="{StaticResource ElevatedGray2}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#E6F0FF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource H1}" Text="Gestão de Componentes"/>
            <TextBlock Style="{StaticResource Subtitle}" Text="Adicione peças manualmente e associe ao Chassi (VIN) de um veículo no Ledger."/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource PremiumCardStyle}" Padding="24" Margin="0,0,0,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Chassi do Veículo (VIN)" Foreground="{StaticResource TextSecondary}" 
                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ComboBox Style="{StaticResource PremiumComboBoxStyle}"
                                  ItemsSource="{Binding Pecas.ListaVins}"
                                  SelectedItem="{Binding Pecas.VinSelecionado, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                  MaxDropDownHeight="200"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Fornecedor" Foreground="{StaticResource TextSecondary}" 
                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <ComboBox Style="{StaticResource PremiumComboBoxStyle}"
                                  ItemsSource="{Binding Pecas.ListaFornecedores}"
                                  SelectedItem="{Binding Pecas.FornecedorSelecionado, Mode=TwoWay}"
                                  MaxDropDownHeight="200">

                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="2,0">
                                        <TextBlock FontFamily="Segoe MDL2 Assets" 
                                                   Text="&#xE81E;" 
                                                   FontSize="14"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   Margin="0,0,8,0" 
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Nome}" 
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                        <TextBlock Text="Nome/Descrição da Peça" Foreground="{StaticResource TextSecondary}" 
                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource PremiumTextBoxStyle}" 
                                 Text="{Binding Pecas.NovaPecaNome, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <TextBlock Text="Peso da peça (kg)" Foreground="{StaticResource TextSecondary}" 
                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource PremiumTextBoxStyle}" 
                                 Text="{Binding Pecas.NovaPecaPesoKg, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}"
                                 InputScope="Number"/>
                    </StackPanel>
                </Grid>

                <Button Grid.Row="1" Style="{StaticResource PrimaryButtonStyle}" 
                        Command="{Binding Pecas.AdicionarPecaManualCommand}"
                        HorizontalAlignment="Right" Margin="0,16,0,0" Padding="28,14"
                        FontSize="15" FontWeight="SemiBold">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE710;" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Registrar Peça" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource PremiumCardStyle}" Padding="24" MinHeight="300">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="Últimas Peças Registradas" Style="{StaticResource H2}" Margin="0,0,16,0"/>
                    <Border Background="{StaticResource ElevatedGray2}" CornerRadius="12" Padding="8,4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Pecas.ListaPecas.Count, StringFormat='Total: {0} peças'}" 
                                   Foreground="{StaticResource TextSecondary}" FontSize="12" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding Pecas.ListaPecas}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource ElevatedGray3}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10" Background="#FFF0E0" Margin="0,0,14,0">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9A1;" FontSize="20" Foreground="{StaticResource AppleOrange}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding NomePeca}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="15"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="VIN: " Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                                                    <TextBlock Text="{Binding VinAssociado}" Foreground="{StaticResource AppleBlue}" FontSize="12" FontWeight="Medium"/>
                                                    <TextBlock Text=" • " Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                                                    <TextBlock Text="{Binding PesoKg, StringFormat='Peso: {0:N2} kg'}" Foreground="{StaticResource AppleOrange}" FontSize="12" FontWeight="Medium"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Border Grid.Column="2" Background="#E6F0FF" CornerRadius="6" Padding="10,4" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="✓ " Foreground="{StaticResource AppleGreen}" FontSize="12" FontWeight="Bold"/>
                                                    <TextBlock Text="Gravado no Ledger" Foreground="{StaticResource AppleBlue}" FontSize="11" FontWeight="Bold"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Nenhuma peça registrada ainda. Adicione a primeira peça no formulário acima." 
                                   Foreground="{StaticResource TextTertiary}" FontSize="14"
                                   VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Pecas.ListaPecas.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>