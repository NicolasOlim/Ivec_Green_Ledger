<UserControl x:Class="WpfIveco.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TÍTULO -->
        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource H1}" Text="Visão Geral do Ledger"/>
            <TextBlock Style="{StaticResource Subtitle}" Text="Acompanhamento em tempo real da cadeia de suprimentos sustentável."/>
        </StackPanel>

        <!-- CARDS -->
        <Grid Grid.Row="1" Margin="0,0,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Card 1: Total de Veículos (caminhão) -->
            <Border Grid.Column="0" Style="{StaticResource PremiumCardStyle}" Margin="0,0,10,0" Padding="24">
                <StackPanel>
                    <Border Width="44" Height="44" Background="#D6EAF8" HorizontalAlignment="Left" CornerRadius="12">
                        <TextBlock FontFamily="Segoe UI Emoji" Text="🚚" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Total de Veículos" Foreground="{StaticResource TextSecondary}" FontSize="14" FontWeight="Medium" Margin="0,16,0,4"/>
                    <TextBlock Text="{Binding Rastreabilidade.TotalVeiculos, FallbackValue='0'}" Foreground="{StaticResource TextPrimary}" FontSize="36" FontWeight="Bold"/>
                    <Border Style="{StaticResource BadgeStyle}" Background="#D6EAF8" Margin="0,10,0,0">
                        <TextBlock Text="Ao Vivo do Firebase" Foreground="#2980B9" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Card 2: Fornecedores Ativos (aperto de mão) -->
            <Border Grid.Column="1" Style="{StaticResource PremiumCardStyle}" Margin="10,0,10,0" Padding="24">
                <StackPanel>
                    <Border Width="44" Height="44" CornerRadius="12" Background="#D5F5E3" HorizontalAlignment="Left">
                        <TextBlock FontFamily="Segoe UI Emoji" Text="🤝" FontSize="26" Foreground="{StaticResource AppleGreen}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Fornecedores Ativos" Foreground="{StaticResource TextSecondary}" FontSize="14" FontWeight="Medium" Margin="0,16,0,4"/>
                    <TextBlock Text="{Binding Fornecedor.TotalFornecedores, FallbackValue='0'}" Foreground="{StaticResource TextPrimary}" FontSize="36" FontWeight="Bold"/>
                    <Border Style="{StaticResource BadgeStyle}" Background="#D5F5E3" Margin="0,10,0,0">
                        <TextBlock Text="Em Conformidade" Foreground="#27AE60" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Card 3: Pegada Média (reciclagem) -->
            <Border Grid.Column="2" Style="{StaticResource PremiumCardStyle}" Margin="10,0,0,0" Padding="24">
                <StackPanel>
                    <Border Width="44" Height="44" CornerRadius="12" Background="#D5F5E3" HorizontalAlignment="Left">
                        <TextBlock FontFamily="Segoe UI Emoji" Text="♻️" FontSize="26" Foreground="#27AE60" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Pegada Média (kg CO2)" Foreground="{StaticResource TextSecondary}" FontSize="14" FontWeight="Medium" Margin="0,16,0,4"/>
                    <TextBlock Text="{Binding Dashboard.PegadaMediaFormatada, FallbackValue='0.0K'}" Foreground="{StaticResource TextPrimary}" FontSize="36" FontWeight="Bold"/>
                    <Border Style="{StaticResource BadgeStyle}" Background="#D5F5E3" Margin="0,10,0,0">
                        <TextBlock Text="Baseado no Ledger" Foreground="#27AE60" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- GRÁFICO -->
        <Border Grid.Row="2" Style="{StaticResource PremiumCardStyle}" Padding="24" MinHeight="350">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Emissões da Cadeia" Style="{StaticResource H2}"/>

                <lvc:CartesianChart Grid.Row="1" 
                            Series="{Binding Analises.EmissoesSeries}" 
                            Margin="0,15,0,0" 
                            LegendLocation="Top">

                    <!-- Eixo X -->
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Labels="{Binding Analises.MesesLabels}" 
                          Foreground="{StaticResource TextSecondary}"
                          FontSize="12">
                            <lvc:Axis.Separator>
                                <lvc:Separator Step="1" StrokeThickness="0"/>
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisX>

                    <!-- Eixo Y -->
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis Title="Ton CO₂" 
              Foreground="{StaticResource TextSecondary}"
              FontSize="12"
              LabelFormatter="{Binding Analises.Formatter}"
              MinValue="0">
                            <lvc:Axis.Separator>
                                <lvc:Separator Stroke="{StaticResource ElevatedGray3}" 
                           StrokeDashArray="4" 
                           StrokeThickness="1"/>
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisY>
                </lvc:CartesianChart>
            </Grid>
        </Border>
    </Grid>
</UserControl>