<UserControl x:Class="WpfIveco.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F7FA">

    <UserControl.Resources>
        <SolidColorBrush x:Key="IvecoGreen" Color="#085A42"/>
        <SolidColorBrush x:Key="IvecoGreenHover" Color="#06402F"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1F2937"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderLight" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.03" BlurRadius="10" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Border" CornerRadius="6" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource IvecoGreen}"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource IvecoGreen}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{StaticResource IvecoGreenHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Visão Geral do Sistema" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                <TextBlock Text="Bem-vindo! Aqui está o resumo das suas integrações hoje." FontSize="14" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Status:" FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,0,12,0" FontWeight="SemiBold" VerticalAlignment="Center"/>

                <Border Background="White" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="16" Padding="12,6" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusBrasilApi" Width="8" Height="8" Fill="#10B981" Margin="0,0,8,0"/>
                        <TextBlock Text="Brasil API" FontSize="13" Foreground="{StaticResource TextPrimary}" FontWeight="Medium"/>
                    </StackPanel>
                </Border>

                <Border Background="White" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="16" Padding="12,6" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusGooglePlaces" Width="8" Height="8" Fill="#10B981" Margin="0,0,8,0"/>
                        <TextBlock Text="Places" FontSize="13" Foreground="{StaticResource TextPrimary}" FontWeight="Medium"/>
                    </StackPanel>
                </Border>

                <Border Background="White" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="16" Padding="12,6" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusNhtsa" Width="8" Height="8" Fill="#10B981" Margin="0,0,8,0"/>
                        <TextBlock Text="NHTSA" FontSize="13" Foreground="{StaticResource TextPrimary}" FontWeight="Medium"/>
                    </StackPanel>
                </Border>

                <Border Background="White" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="16" Padding="12,6">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusMercadoLivre" Width="8" Height="8" Fill="#EF4444" Margin="0,0,8,0"/>
                        <TextBlock Text="Mercado Livre" FontSize="13" Foreground="{StaticResource TextPrimary}" FontWeight="Medium"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,32">
            <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Consultas Hoje" FontSize="13" Foreground="{StaticResource TextSecondary}" FontWeight="Medium" Margin="0,0,0,8"/>
                    <TextBlock Text="1.248" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="↑ 12% vs. ontem" FontSize="12" Foreground="#10B981" Margin="0,8,0,0" FontWeight="Medium"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Falhas de Integração" FontSize="13" Foreground="{StaticResource TextSecondary}" FontWeight="Medium" Margin="0,0,0,8"/>
                    <TextBlock Text="0,3%" FontSize="28" FontWeight="Bold" Foreground="#EF4444"/>
                    <TextBlock Text="2 instabilidades nas últimas 24h" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Tempo de Resposta (API)" FontSize="13" Foreground="{StaticResource TextSecondary}" FontWeight="Medium" Margin="0,0,0,8"/>
                    <TextBlock Text="120 ms" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Média ideal atingida" FontSize="12" Foreground="#10B981" Margin="0,8,0,0" FontWeight="Medium"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="Uso do Servidor" FontSize="13" Foreground="{StaticResource TextSecondary}" FontWeight="Medium" Margin="0,0,0,8"/>
                    <TextBlock Text="42%" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Estável" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" 
                x:Name="PainelChamado" 
                Style="{StaticResource CardStyle}"
                Padding="32"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Width="550">

            <StackPanel>
                <TextBlock Text="Registrar Solicitação de Suporte" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                <TextBlock Text="Preencha os dados abaixo. Nossa equipe retornará o mais rápido possível." FontSize="14" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,32"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Tipo de Problema" FontSize="13" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8" FontWeight="Medium"/>
                        <ComboBox x:Name="ComboTipoProblema" SelectedIndex="0" Height="42">
                            <ComboBoxItem>Problema Técnico</ComboBoxItem>
                            <ComboBoxItem>API Fora do Ar</ComboBoxItem>
                            <ComboBoxItem>Suporte Direto</ComboBoxItem>
                            <ComboBoxItem>Dúvida Operacional</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Prioridade" FontSize="13" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8" FontWeight="Medium"/>
                        <ComboBox SelectedIndex="1" Height="42">
                            <ComboBoxItem>Baixa</ComboBoxItem>
                            <ComboBoxItem>Normal</ComboBoxItem>
                            <ComboBoxItem>Alta / Urgente</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Nome do Solicitante" FontSize="13" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8" FontWeight="Medium"/>
                <TextBox x:Name="TxtNome" Margin="0,0,0,16" Height="42" Text="{Binding UsuarioLogadoNome, FallbackValue='Colaborador Padrão'}"/>

                <TextBlock Text="Descrição do Problema" FontSize="13" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8" FontWeight="Medium"/>
                <TextBox x:Name="TxtDescricao" Height="120" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,32" VerticalScrollBarVisibility="Auto"/>

                <Button Content="ENVIAR CHAMADO" 
                        Style="{StaticResource BtnPrimary}" 
                        Click="EnviarChamado_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>