<UserControl x:Class="WpfIveco.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TÍTULO -->
        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource H1}" Text="Visão Geral do Ledger"/>
            <TextBlock Style="{StaticResource Subtitle}" Text="Acompanhamento em tempo real da cadeia de suprimentos sustentável."/>
        </StackPanel>

        <!-- CARDS -->
        <Grid Grid.Row="1" Margin="0,0,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource PremiumCardStyle}" Margin="0,0,10,0" Padding="24">
                <StackPanel>
                    <Border Width="40" Height="40" Background="#E6F0FF" HorizontalAlignment="Left" CornerRadius="10">
                        <TextBlock Text=" " FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Total de Veículos" Foreground="{StaticResource TextSecondary}" FontSize="14" FontWeight="Medium" Margin="0,16,0,4"/>
                    <TextBlock Text="{Binding Rastreabilidade.TotalVeiculos, FallbackValue='0'}" Foreground="{StaticResource TextPrimary}" FontSize="36" FontWeight="Bold"/>
                    <Border Style="{StaticResource BadgeStyle}" Background="#E6F0FF" Margin="0,10,0,0">
                        <TextBlock Text="Ao Vivo do Firebase" Foreground="{StaticResource AppleBlue}" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource PremiumCardStyle}" Margin="10,0,10,0" Padding="24">
                <StackPanel>
                    <Border Width="40" Height="40" CornerRadius="10" Background="#E6F0FF" HorizontalAlignment="Left">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE710;" FontSize="18" Foreground="{StaticResource AppleBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Fornecedores Ativos" Foreground="{StaticResource TextSecondary}" FontSize="14" FontWeight="Medium" Margin="0,16,0,4"/>
                    <TextBlock Text="{Binding Fornecedor.TotalFornecedores, FallbackValue='0'}" Foreground="{StaticResource TextPrimary}" FontSize="36" FontWeight="Bold"/>
                    <Border Style="{StaticResource BadgeStyle}" Background="#E6F0FF" Margin="0,10,0,0">
                        <TextBlock Text="Em Conformidade" Foreground="{StaticResource AppleBlue}" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource PremiumCardStyle}" Margin="10,0,0,0" Padding="24">
                <StackPanel>
                    <Border Width="40" Height="40" CornerRadius="10" Background="#FFF0E0" HorizontalAlignment="Left">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9D9;" FontSize="18" Foreground="{StaticResource AppleOrange}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Pegada Média (kg CO2)" Foreground="{StaticResource TextSecondary}" FontSize="14" FontWeight="Medium" Margin="0,16,0,4"/>
                    <TextBlock Text="{Binding Dashboard.PegadaMediaFormatada, FallbackValue='0.0K'}" Foreground="{StaticResource TextPrimary}" FontSize="36" FontWeight="Bold"/>
                    <Border Style="{StaticResource BadgeStyle}" Background="#FFF0E0" Margin="0,10,0,0">
                        <TextBlock Text="Baseado no Ledger" Foreground="{StaticResource AppleOrange}" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- GRÁFICO E TRANSAÇÕES -->
        <!-- Gráfico de Emissões -->
        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource PremiumCardStyle}" Margin="0,0,10,0" Padding="24" MinHeight="350">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Emissões da Cadeia (YTD)" Style="{StaticResource H2}"/>

                <lvc:CartesianChart Grid.Row="1" 
                            Series="{Binding Analises.EmissoesSeries}" 
                            Margin="0,15,0,0" 
                            LegendLocation="Top">

                    <!-- Eixo X -->
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Labels="{Binding Analises.MesesLabels}" 
                          Foreground="{StaticResource TextSecondary}"
                          FontSize="12">
                            <lvc:Axis.Separator>
                                <lvc:Separator Step="1" StrokeThickness="0"/>
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisX>

                    <!-- Eixo Y -->
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis Title="Ton CO₂" 
              Foreground="{StaticResource TextSecondary}"
              FontSize="12"
              LabelFormatter="{Binding Analises.Formatter}"
              MinValue="0">
                            <!-- FORÇA O EIXO Y A COMEÇAR EM 0 -->
                            <lvc:Axis.Separator>
                                <lvc:Separator Stroke="{StaticResource ElevatedGray3}" 
                           StrokeDashArray="4" 
                           StrokeThickness="1"/>
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisY>
                </lvc:CartesianChart>
            </Grid>
        </Border>
    </Grid>
</UserControl>