<UserControl x:Class="WpfIveco.Views.AnalisesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             FontFamily="Segoe UI Variable, Segoe UI, Helvetica Neue, sans-serif"
             Background="#F3F4F6">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="Auto"/>
                <!-- Cards Superiores -->
                <RowDefinition Height="Auto"/>
                <!-- Gráficos -->
                <RowDefinition Height="*"/>
                <!-- Tabelas e Listas -->
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <TextBlock Grid.Row="0" Text="Dashboard ESG" FontSize="28" FontWeight="Bold" Foreground="#0A5B43" Margin="0,0,0,24"/>

            <!-- 4 CARDS DE RESUMO -->
            <Grid Grid.Row="1" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#0A5B43" CornerRadius="12" Padding="20" Height="100" Margin="0,0,12,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.1" Color="Black"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding TotalEmissoes, StringFormat={}{0:N0} ton}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Emissões de CO2 Totais" FontSize="13" Foreground="#D1FAE5" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#1B7055" CornerRadius="12" Padding="20" Height="100" Margin="6,0,6,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.1" Color="Black"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding FornecedoresVerdes}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Fornecedores Certificados" FontSize="13" Foreground="#D1FAE5" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#2E8B57" CornerRadius="12" Padding="20" Height="100" Margin="6,0,6,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.1" Color="Black"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding PecasReaproveitadas}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Peças Reaproveitadas" FontSize="13" Foreground="#D1FAE5" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="#4BAC50" CornerRadius="12" Padding="20" Height="100" Margin="12,0,0,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.1" Color="Black"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding EconomiaGerada}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Economia Estimada" FontSize="13" Foreground="#ECFDF5" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- GRÁFICOS -->
            <Grid Grid.Row="2" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20" Height="320" Margin="0,0,12,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.05" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Emissões por Categoria" FontSize="16" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,12"/>
                        <lvc:PieChart Grid.Row="1" Series="{Binding GraficoPizzaSeries}" LegendLocation="Right" InnerRadius="60">
                            <lvc:PieChart.DataTooltip>
                                <lvc:DefaultTooltip Background="#111827" Foreground="White" BorderThickness="0" CornerRadius="8" Padding="10"/>
                            </lvc:PieChart.DataTooltip>
                        </lvc:PieChart>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20" Height="320" Margin="12,0,0,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.05" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Redução Mensal de Carbono (ton)" FontSize="16" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,12"/>
                        <lvc:CartesianChart Grid.Row="1" Series="{Binding GraficoBarrasSeries}" Margin="0,10,0,0">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Labels="{Binding MesesLabels}" Foreground="#6B7280"/>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis MinValue="0" Foreground="#6B7280"/>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </Grid>
                </Border>
            </Grid>

            <!-- SESSÃO INFERIOR (DATAGRID + TOP FORNECEDORES) -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <!-- Espaço maior para a tabela -->
                    <ColumnDefinition Width="1*"/>
                    <!-- Espaço menor para o ranking -->
                </Grid.ColumnDefinitions>

                <!-- DATAGRID (Últimas Avaliações) -->
                <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20" MinHeight="300" Margin="0,0,12,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.05" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Últimas Avaliações de Fornecedores" FontSize="16" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,16"/>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding UltimasAvaliacoes}" 
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  Background="Transparent" BorderThickness="0"
                                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F3F4F6"
                                  RowHeight="48" IsReadOnly="True" HeadersVisibility="Column">

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#ECFDF5"/>
                                    <Setter Property="Foreground" Value="#0A5B43"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="White"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F8FAFC"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Fornecedor" Binding="{Binding Fornecedor}" Width="2*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="12,0,0,0"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Material" Binding="{Binding Material}" Width="1.5*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#4B5563"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Pegada (kg CO2)" Binding="{Binding PegadaCarbono}" Width="1.2*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#0A5B43"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Certificação" Binding="{Binding Status}" Width="1*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#D97706"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- TOP FORNECEDORES (Ranking) -->
                <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20" MinHeight="300" Margin="12,0,0,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.05" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="🏆 Top Fornecedores" FontSize="16" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,16"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding TopFornecedores}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F9FAFB" CornerRadius="8" Margin="0,0,0,8" Padding="12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Posição -->
                                                <Border Grid.Column="0" Background="{Binding CorDestaque}" Width="32" Height="32" CornerRadius="16" Margin="0,0,12,0">
                                                    <TextBlock Text="{Binding Posicao}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>

                                                <!-- Info do Fornecedor -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Nome}" FontWeight="SemiBold" Foreground="#1F2937" FontSize="14" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Categoria}" Foreground="#6B7280" FontSize="12" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>

                                                <!-- Score -->
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="8,0,0,0">
                                                    <TextBlock Text="{Binding PontuacaoESG, StringFormat={}{0} pts}" FontWeight="Bold" Foreground="#0A5B43" FontSize="15" HorizontalAlignment="Right"/>
                                                    <TextBlock Text="Score" Foreground="#9CA3AF" FontSize="10" HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>