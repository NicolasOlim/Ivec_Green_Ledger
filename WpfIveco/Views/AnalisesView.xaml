<UserControl x:Class="WpfIveco.Views.AnalisesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             FontFamily="Segoe UI Variable, Segoe UI, Helvetica Neue, sans-serif">
    <Grid>
        <!-- Fundo Decorativo com Folhas (Tema Green Ledger) -->
        <Canvas Opacity="0.4" IsHitTestVisible="False">
            <TextBlock Text="🌿" FontSize="200" Foreground="#E5F3ED" Opacity="0.6" Canvas.Right="-50" Canvas.Top="-50">
                <TextBlock.RenderTransform>
                    <RotateTransform Angle="25" CenterX="100" CenterY="100"/>
                </TextBlock.RenderTransform>
            </TextBlock>
            <TextBlock Text="🌿" FontSize="120" Foreground="#E5F3ED" Opacity="0.4" Canvas.Left="-30" Canvas.Bottom="100">
                <TextBlock.RenderTransform>
                    <RotateTransform Angle="-45" CenterX="60" CenterY="60"/>
                </TextBlock.RenderTransform>
            </TextBlock>
        </Canvas>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TÍTULO COM ÍCONE -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24" Orientation="Horizontal">
                <Border Width="56" Height="56" CornerRadius="16" Background="#ECFDF5" BorderBrush="#D1FAE5" BorderThickness="1" Margin="0,0,16,0">
                    <TextBlock Text="🌿" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Análise de Sustentabilidade" FontSize="28" FontWeight="Bold" Foreground="#0A5B43"/>
                    <TextBlock Text="Métricas detalhadas para emissão de relatórios corporativos ESG." FontSize="15" Foreground="#6B7280" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- CONTEÚDO -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- GRÁFICO DE PIZZA (CARD ESQUERDO) -->
                <Border Grid.Column="0" Background="White" CornerRadius="16" BorderBrush="#E5E5EA" BorderThickness="1" Margin="0,0,10,0" Padding="24" MinHeight="400">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.05" Color="#0A5B43"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Distribuição de Emissões" FontSize="18" FontWeight="Bold" Foreground="#111827"/>

                        <lvc:PieChart Grid.Row="1" 
                                      Series="{Binding Analises.DistribuicaoSeries}" 
                                      Margin="0,16,0,0" 
                                      LegendLocation="Bottom"
                                      Foreground="#4B5563">
                            <lvc:PieChart.DataTooltip>
                                <lvc:DefaultTooltip Background="#111827" Foreground="White" BorderThickness="0" CornerRadius="8" Padding="10"/>
                            </lvc:PieChart.DataTooltip>
                        </lvc:PieChart>
                    </Grid>
                </Border>

                <!-- TOP FORNECEDORES VERDES (CARD DIREITO) -->
                <Border Grid.Column="1" Background="White" CornerRadius="16" BorderBrush="#E5E5EA" BorderThickness="1" Margin="10,0,0,0" Padding="24" MinHeight="400">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.05" Color="#0A5B43"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Top Fornecedores Verdes" FontSize="18" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,16"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                            <ItemsControl ItemsSource="{Binding Analises.TopFornecedores}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Linha do Fornecedor -->
                                        <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Padding="0,8,0,16" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Ícone Status (Laranja ou Verde Iveco) -->
                                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Margin="0,0,16,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <!-- Laranja Mute padrão para Pendente -->
                                                            <Setter Property="Background" Value="#F59E0B"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Certificado}" Value="ISO 14001">
                                                                    <!-- Verde Iveco para Certificado -->
                                                                    <Setter Property="Background" Value="#1B7055"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Certificado}" Value="Pendente">
                                                                    <Setter Property="Background" Value="#F59E0B"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE73E;" FontSize="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>

                                                <!-- Detalhes do Fornecedor -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Nome}" Foreground="#111827" FontWeight="Bold" FontSize="15"/>
                                                    <TextBlock Text="{Binding Localizacao}" Foreground="#6B7280" FontSize="12" Margin="0,2,0,4"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Peças: " Foreground="#9CA3AF" FontSize="12"/>
                                                        <!-- Quantidade de peças no Verde Destaque -->
                                                        <TextBlock Text="{Binding TotalPecas}" Foreground="#0A5B43" FontSize="12" FontWeight="Bold"/>
                                                        <TextBlock Text="  •  Pegada: " Foreground="#9CA3AF" FontSize="12"/>
                                                        <TextBlock Text="{Binding PegadaMedia, StringFormat={}{0:N1} kg CO2}" Foreground="#D97706" FontSize="12" FontWeight="Bold"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- Badge de Certificação -->
                                                <Border Grid.Column="2" CornerRadius="6" Padding="10,6" VerticalAlignment="Top">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#FEF3C7"/>
                                                            <!-- Fundo amarelado pendente -->
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Certificado}" Value="ISO 14001">
                                                                    <Setter Property="Background" Value="#ECFDF5"/>
                                                                    <!-- Fundo esverdeado aprovado -->
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Certificado}" FontSize="11" FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#B45309"/>
                                                                <!-- Texto amarelado pendente -->
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Certificado}" Value="ISO 14001">
                                                                        <Setter Property="Foreground" Value="#047857"/>
                                                                        <!-- Texto verde aprovado -->
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>