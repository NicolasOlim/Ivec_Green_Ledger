<UserControl x:Class="WpfIveco.Views.RastreabilidadeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource H1}" Text="Rastreabilidade de Veículos"/>
            <TextBlock Style="{StaticResource Subtitle}" Text="Consulte o genoma digital de um veículo para validar a origem de componentes."/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource PremiumCardStyle}" Padding="24" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Busca no Blockchain" Style="{StaticResource H2}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Margin="0,0,16,0">
                        <TextBox Style="{StaticResource PremiumTextBoxStyle}" Text="{Binding Rastreabilidade.PesquisaVin, UpdateSourceTrigger=PropertyChanged}" MaxLength="17"/>
                        <TextBlock Text="Insira o número VIN do veículo..." Foreground="{StaticResource TextTertiary}" VerticalAlignment="Center" Margin="14,0,0,0" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Rastreabilidade.PesquisaVin}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Rastreabilidade.PesquisarVinCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE721;" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Rastrear Origem" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource PremiumCardStyle}" Padding="24" MinHeight="350">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Veículos Disponíveis no Banco" Style="{StaticResource H2}" Margin="0,0,0,10"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="400">
                    <ItemsControl ItemsSource="{Binding Rastreabilidade.ListaVeiculos}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource ElevatedGray2}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="12" Padding="16,12" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="38" Height="38" CornerRadius="8" Background="{StaticResource ElevatedGray3}" Margin="0,0,12,0">
                                            <TextBlock Text=" " FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Modelo, FallbackValue='Modelo Iveco'}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="14"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="VIN: " Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                                                <TextBlock Text="{Binding Vin}" Foreground="{StaticResource AppleBlue}" FontSize="12" FontWeight="Medium"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding DataMontagem, StringFormat={}{0:dd/MM/yyyy}}" Foreground="{StaticResource TextSecondary}" FontSize="13" HorizontalAlignment="Right"/>
                                            <Border Background="#E6F0FF" CornerRadius="4" Padding="6,2" Margin="0,4,0,0" HorizontalAlignment="Right">
                                                <TextBlock Text="Sincronizado" Foreground="{StaticResource AppleBlue}" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>