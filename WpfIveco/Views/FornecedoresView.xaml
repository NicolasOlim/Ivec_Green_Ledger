<UserControl x:Class="WpfIveco.Views.FornecedoresView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             FontFamily="Segoe UI Variable, Segoe UI, Helvetica Neue, sans-serif">

    <UserControl.Resources>
        <DropShadowEffect x:Key="DropShadowEffect" BlurRadius="20" ShadowDepth="4" Opacity="0.05" Color="#0A5B43"/>

        <Style x:Key="PremiumTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="#0A5B43"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="#0A5B43"/>
                                <Setter Property="Background" TargetName="border" Value="#F0FDF4"/>
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter Property="Background" TargetName="border" Value="#F9FAFB"/>
                                <Setter Property="BorderBrush" TargetName="border" Value="#E5E5EA"/>
                                <Setter Property="Foreground" Value="#4B5563"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PremiumComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter x:Name="ContentPresenter" Grid.Column="0" 
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="12,0,12,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                                    <ToggleButton x:Name="PART_DropDownToggle" Grid.Column="1" Focusable="False" ClickMode="Press"
                                                  Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" Margin="0,0,14,0"
                                                  VerticalAlignment="Center" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                        <Path Fill="#6B7280" Data="M0,0 L5,5 L10,0 Z" Width="12" Height="7" Stretch="Fill"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                   MaxHeight="250" AllowsTransparency="True" StaysOpen="False">
                                <Border Background="White" CornerRadius="8" BorderBrush="#E5E5EA" BorderThickness="1"
                                        Margin="0,6,0,0" Padding="6" Effect="{StaticResource DropShadowEffect}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#0A5B43"/>
                                <Setter TargetName="Border" Property="Background" Value="#F0FDF4"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#0A5B43"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="#F3F4F6"/>
                                <Setter Property="Foreground" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Padding" Value="14,10"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#111827"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter Property="Background" Value="#F3F4F6"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#ECFDF5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="37*"/>
            <ColumnDefinition Width="408*"/>
        </Grid.ColumnDefinitions>
        <Canvas Opacity="0.4" IsHitTestVisible="False" Grid.ColumnSpan="2">
            <TextBlock Text="🌿" FontSize="200" Foreground="#E5F3ED" Opacity="0.6" Canvas.Right="-50" Canvas.Top="-50">
                <TextBlock.RenderTransform>
                    <RotateTransform Angle="25" CenterX="100" CenterY="100"/>
                </TextBlock.RenderTransform>
            </TextBlock>
            <TextBlock Text="🌿" FontSize="120" Foreground="#E5F3ED" Opacity="0.4" Canvas.Left="-30" Canvas.Bottom="100">
                <TextBlock.RenderTransform>
                    <RotateTransform Angle="-45" CenterX="60" CenterY="60"/>
                </TextBlock.RenderTransform>
            </TextBlock>
        </Canvas>

        <Grid Margin="10,10,10,10" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,24" Orientation="Horizontal">
                <Border Width="56" Height="56" CornerRadius="16" Background="#EFF6FF" BorderBrush="#DBEAFE" BorderThickness="1" Margin="0,0,16,0">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE825;" FontSize="24" Foreground="#1D4ED8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Gestão de Fornecedores" FontSize="28" FontWeight="Bold" Foreground="#0A5B43"/>
                    <TextBlock Text="Cadastre parceiros na rede permissionada do Ledger." FontSize="15" Foreground="#6B7280" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="1" Background="White" CornerRadius="16" BorderBrush="#E5E5EA" BorderThickness="1" Padding="32" Effect="{StaticResource DropShadowEffect}" VerticalAlignment="Top">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Integração Receita Federal" FontSize="18" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,16"/>

                    <Grid Grid.Row="1" Margin="0,0,0,32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Margin="0,0,16,0">
                            <TextBox Style="{StaticResource PremiumTextBoxStyle}" 
                                     Text="{Binding Fornecedor.CnpjBusca, UpdateSourceTrigger=PropertyChanged}"
                                     TextChanged="CnpjTextBox_TextChanged"
                                     PreviewTextInput="NumberValidationTextBox"
                                     MaxLength="18"
                                     FontFamily="Consolas, Segoe UI" FontWeight="SemiBold" FontSize="15"/>

                            <TextBlock Text="Ex: 00.000.000/0000-00" Foreground="#9CA3AF" FontSize="14" 
                                       VerticalAlignment="Center" Margin="16,0,0,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Fornecedor.CnpjBusca}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <Button Grid.Column="1" Command="{Binding Fornecedor.ConsultarCnpjCommand}" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="searchBorder" Background="#EFF6FF" BorderBrush="#2563EB" BorderThickness="1.5" CornerRadius="8" Padding="20,10">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8B6;" FontSize="16" Foreground="#2563EB" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Consultar CNPJ" Foreground="#2563EB" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="searchBorder" Property="Background" Value="#DBEAFE"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="searchBorder" Property="Background" Value="#BFDBFE"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,0,0,32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Razão Social" Foreground="#4B5563" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBox Style="{StaticResource PremiumTextBoxStyle}" 
                                     Text="{Binding Fornecedor.NomeFornecedorEncontrado}" 
                                     IsReadOnly="True" FontWeight="SemiBold"/>

                            <!-- Status RFB – CORRIGIDO: removido o atributo Style duplicado -->
                            <TextBlock Text="Status RFB" Foreground="#4B5563" FontSize="13" FontWeight="SemiBold" Margin="0,20,0,8"/>
                            <TextBox Text="{Binding Fornecedor.StatusRfb}" 
                                     IsReadOnly="True" FontWeight="Bold">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource PremiumTextBoxStyle}">
                                        <Setter Property="Foreground" Value="#059669"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Fornecedor.StatusRfb}" Value="SUSPENSA">
                                                <Setter Property="Foreground" Value="#D97706"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Fornecedor.StatusRfb}" Value="INATIVA">
                                                <Setter Property="Foreground" Value="#EF4444"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Fornecedor.StatusRfb}" Value="Não encontrado">
                                                <Setter Property="Foreground" Value="#EF4444"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Endereço Sede" Foreground="#4B5563" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>

                            <Border Background="#F9FAFB" CornerRadius="8" Padding="14,12" MinHeight="46" BorderBrush="#E5E5EA" BorderThickness="1.5">
                                <TextBlock Text="{Binding Fornecedor.LocalizacaoFornecedorEncontrado}" 
                                           Foreground="#4B5563" FontSize="14" FontWeight="Medium"
                                           TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </Border>

                            <!-- Categoria ESG – ComboBox corrigido -->
                            <TextBlock Text="Categoria ESG (Atribuída)" Foreground="#4B5563" FontSize="13" FontWeight="SemiBold" Margin="0,20,0,8"/>
                            <ComboBox Style="{StaticResource PremiumComboBoxStyle}" 
          SelectedValue="{Binding Fornecedor.CategoriaEsg, Mode=TwoWay}"
          SelectedValuePath="Content"
          IsEditable="False" IsReadOnly="False">
                                <ComboBoxItem>Ouro</ComboBoxItem>
                                <ComboBoxItem>Prata</ComboBoxItem>
                                <ComboBoxItem>Bronze</ComboBoxItem>
                                <ComboBoxItem>Pendente</ComboBoxItem>
                                <ComboBoxItem>Não avaliado</ComboBoxItem>
                                <ComboBoxItem>Sem dados</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <Separator Grid.Row="3" Margin="0,0,0,24" Background="#E5E5EA"/>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Fornecedor.MensagemCadastro}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Fornecedor.MensagemCadastro}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#xE73E;"/>
                                        <Setter Property="Foreground" Value="#10B981"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Fornecedor.IsErro}" Value="True">
                                                <Setter Property="Text" Value="&#xEA39;"/>
                                                <Setter Property="Foreground" Value="#EF4444"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock Text="{Binding Fornecedor.MensagemCadastro}" FontSize="14" VerticalAlignment="Center" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#10B981"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Fornecedor.IsErro}" Value="True">
                                                <Setter Property="Foreground" Value="#EF4444"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <Button Grid.Column="1" Command="{Binding Fornecedor.SalvarFornecedorCommand}" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="#0A5B43" CornerRadius="8" Padding="32,14">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74E;" FontSize="16" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Registrar no Ledger" Foreground="White" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#1B7055"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#114736"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>