<UserControl x:Class="WpfIveco.Views.AjustesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource H1}" Text="Configurações do Node"/>
            <TextBlock Style="{StaticResource Subtitle}" Text="Gerencie a comunicação com a rede, API externa e o simulador local."/>
        </StackPanel>
        <Border Grid.Row="1" Style="{StaticResource PremiumCardStyle}" Padding="30">
            <StackPanel>
                <TextBlock Text="Conectividade da Rede" Style="{StaticResource H2}"/>
                <TextBlock Text="Endereço Base da API (Endpoint)" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox Style="{StaticResource PremiumTextBoxStyle}" Text="{Binding ApiUrlConfig, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,30"/>
                <Border BorderBrush="{StaticResource ElevatedGray3}" BorderThickness="0,0,0,1" Margin="0,0,0,30"/>
                <TextBlock Text="Ferramentas de Desenvolvimento" Style="{StaticResource H2}"/>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Simulador de Chão de Fábrica (MOCK IoT)" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="Habilita a geração contínua de telemetria e registros de chassi simulados para testes de carga no Firebase." Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                        <TextBlock Text="{Binding StatusSimulador, FallbackValue='Desativado'}" Foreground="{StaticResource TextSecondary}" Margin="0,0,16,0" VerticalAlignment="Center" FontWeight="Bold"/>
                        <Button Command="{Binding LigarDesligarSimuladorCommand}" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="{StaticResource ElevatedGray3}" CornerRadius="16" Width="52" Height="32">
                                        <Ellipse x:Name="knob" Width="24" Height="24" Fill="White" HorizontalAlignment="Left" Margin="4,0,0,0"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource AppleGreen}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>