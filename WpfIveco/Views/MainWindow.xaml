            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{StaticResource AppBackground}"/>
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoggedIn}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Button Width="14" Height="14" Margin="24" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="Hand" Click="CloseButton_Click" ToolTip="Fechar">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Ellipse Fill="#FF5F56"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Border Width="450" Style="{StaticResource PremiumCardStyle}" Padding="40" Background="White" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel>
                        <Border Width="60" Height="60" CornerRadius="16" Background="{StaticResource ElevatedGray2}" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xEB41;" FontSize="32" Foreground="{StaticResource AppleGreen}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock HorizontalAlignment="Center" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Iveco Green Ledger"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ModoCadastro}" Value="True">
                                            <Setter Property="Text" Value="Criar Nova Conta"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ModoCadastro}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Nome Completo" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="SemiBold" Margin="0,20,0,8"/>
                            <TextBox Style="{StaticResource PremiumTextBoxStyle}" Text="{Binding CadastroNome, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                            <TextBlock Text="Tipo de Acesso (Perfil)" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <RadioButton Content="Usu rio Normal" Foreground="{StaticResource TextPrimary}" IsChecked="True" GroupName="Perfil" Margin="0,0,20,0"/>
                                <RadioButton Content="Administrador" Foreground="{StaticResource TextPrimary}" GroupName="Perfil"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="Endere o de E-mail" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="SemiBold" Margin="0,20,0,8"/>
                        <TextBox Style="{StaticResource PremiumTextBoxStyle}" Text="{Binding LoginEmail, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                        <TextBlock Text="Palavra-Passe" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource PremiumTextBoxStyle}" Text="{Binding LoginSenha, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,30"/>
                        <Button Padding="0,14" Cursor="Hand" BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Command" Value="{Binding FazerLoginCommand}"/>
                                    <Setter Property="Background" Value="{StaticResource AppleBlue}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ModoCadastro}" Value="True">
                                            <Setter Property="Command" Value="{Binding FazerCadastroCommand}"/>
                                            <Setter Property="Background" Value="{StaticResource AppleGreen}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12">
                                        <TextBlock FontWeight="Bold" FontSize="15" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="0,14">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Entrar no Sistema"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.ModoCadastro, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                            <Setter Property="Text" Value="Concluir Registo"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.65"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Command="{Binding AlternarModoAuthCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,20,0,0">
                            <TextBlock Foreground="{StaticResource AppleBlue}" TextDecorations="Underline" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="N o tem conta? Registre-se aqui."/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.ModoCadastro, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                <Setter Property="Text" Value="J  tem uma conta? Fa a Login."/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>