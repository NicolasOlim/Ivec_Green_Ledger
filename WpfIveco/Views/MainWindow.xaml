                                            <Setter Property="Text" Value="Criar Nova Conta"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ModoCadastro}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Text="Nome Completo" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="SemiBold" Margin="0,20,0,8"/>
                            <TextBox Style="{StaticResource PremiumTextBoxStyle}" Text="{Binding CadastroNome, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                            <TextBlock Text="Tipo de Acesso (Perfil)" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <RadioButton Content="Usuário Normal" Foreground="White" IsChecked="True" GroupName="Perfil" Margin="0,0,20,0"
                                             Command="{Binding MudarAbaCommand}" CommandParameter="Usuario" />
                                <RadioButton Content="Administrador" Foreground="White" GroupName="Perfil" 
                                             Command="{Binding MudarAbaCommand}" CommandParameter="Admin"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="Endereço de E-mail" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="SemiBold" Margin="0,20,0,8"/>
                        <TextBox Style="{StaticResource PremiumTextBoxStyle}" Text="{Binding LoginEmail, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                        <TextBlock Text="Palavra-Passe" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource PremiumTextBoxStyle}" Text="{Binding LoginSenha, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,30" />

                        <Button Background="{StaticResource AppleBlue}" Foreground="White" Padding="0,14" Cursor="Hand" BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Command" Value="{Binding FazerLoginCommand}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ModoCadastro}" Value="True">
                                            <Setter Property="Command" Value="{Binding FazerCadastroCommand}"/>
                                            <Setter Property="Background" Value="{StaticResource AppleGreen}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12">
                                        <TextBlock FontWeight="Bold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Entrar no Sistema"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.ModoCadastro, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                            <Setter Property="Text" Value="Concluir Registo"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.65"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Command="{Binding AlternarModoAuthCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,20,0,0">
                            <TextBlock Foreground="{StaticResource TextSecondary}" TextDecorations="Underline" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Não tem conta? Registre-se aqui."/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.ModoCadastro, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                <Setter Property="Text" Value="Já tem uma conta? Faça Login."/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Window>