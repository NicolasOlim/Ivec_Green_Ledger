<UserControl x:Class="WpfIveco.Views.RelatoriosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             FontFamily="Segoe UI Variable, Segoe UI, Helvetica Neue, sans-serif">

    <UserControl.Resources>
        <DropShadowEffect x:Key="DropShadowEffect" BlurRadius="20" ShadowDepth="4" Opacity="0.05" Color="#0A5B43"/>

        <!-- ESTILO DOS CARDS DE SELEÇÃO (RADIOBUTTON CUSTOMIZADO) -->
        <Style x:Key="ReportOptionCardStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E5EA"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="CardBorder" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Conteúdo (Ícone e Textos) -->
                                <ContentPresenter Grid.Column="0" VerticalAlignment="Center"/>

                                <!-- Indicador Visual de Seleção (Bolinha) -->
                                <Border x:Name="CheckRing" Grid.Column="1" Width="24" Height="24" CornerRadius="12"
                                        BorderBrush="#D1D5DB" BorderThickness="2" Background="White" VerticalAlignment="Center">
                                    <Ellipse x:Name="CheckDot" Width="10" Height="10" Fill="#0A5B43" Opacity="0"/>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="#F9FAFB"/>
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#D1D5DB"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="#F0FDF4"/>
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#0A5B43"/>
                                <Setter TargetName="CheckRing" Property="BorderBrush" Value="#0A5B43"/>
                                <Setter TargetName="CheckDot" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Fundo Decorativo com Folhas (Para manter a identidade visual) -->
        <Canvas Opacity="0.4" IsHitTestVisible="False">
            <TextBlock Text="🌿" FontSize="200" Foreground="#E5F3ED" Opacity="0.6" Canvas.Right="-50" Canvas.Top="-50">
                <TextBlock.RenderTransform>
                    <RotateTransform Angle="25" CenterX="100" CenterY="100"/>
                </TextBlock.RenderTransform>
            </TextBlock>
            <TextBlock Text="🌿" FontSize="120" Foreground="#E5F3ED" Opacity="0.4" Canvas.Left="-30" Canvas.Bottom="100">
                <TextBlock.RenderTransform>
                    <RotateTransform Angle="-45" CenterX="60" CenterY="60"/>
                </TextBlock.RenderTransform>
            </TextBlock>
        </Canvas>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- CABEÇALHO -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24" Orientation="Horizontal">
                <Border Width="56" Height="56" CornerRadius="16" Background="#ECFDF5" BorderBrush="#D1FAE5" BorderThickness="1" Margin="0,0,16,0">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A5;" FontSize="24" Foreground="#0A5B43" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Central de Relatórios" FontSize="28" FontWeight="Bold" Foreground="#0A5B43"/>
                    <TextBlock Text="Exporte os dados consolidados da cadeia de suprimentos em formato PDF oficial." FontSize="15" Foreground="#6B7280" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- CARD PRINCIPAL -->
            <Border Grid.Row="1" Background="White" CornerRadius="16" BorderBrush="#E5E5EA" BorderThickness="1" Padding="32" Effect="{StaticResource DropShadowEffect}" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="Selecione o tipo de relatório desejado" FontSize="16" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,24"/>

                    <!-- OPÇÃO 1: VEÍCULOS -->
                    <RadioButton GroupName="RelatorioGroup" IsChecked="True" Checked="RadioButton_Checked" Tag="Veiculos" Style="{StaticResource ReportOptionCardStyle}">
                        <StackPanel Orientation="Horizontal">
                            <!-- Ícone -->
                            <Border Width="44" Height="44" CornerRadius="10" Background="#ECFDF5" Margin="0,0,16,0">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE804;" FontSize="20" Foreground="#0A5B43" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <!-- Textos -->
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Relatório Geral de Veículos" Foreground="#111827" FontWeight="Bold" FontSize="15"/>
                                <TextBlock Text="Dados completos de rastreabilidade e histórico da frota." Foreground="#6B7280" FontSize="13" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <!-- OPÇÃO 2: FORNECEDORES -->
                    <RadioButton GroupName="RelatorioGroup" Checked="RadioButton_Checked" Tag="Fornecedores" Style="{StaticResource ReportOptionCardStyle}">
                        <StackPanel Orientation="Horizontal">
                            <!-- Ícone -->
                            <Border Width="44" Height="44" CornerRadius="10" Background="#EFF6FF" Margin="0,0,16,0">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE825;" FontSize="20" Foreground="#1D4ED8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <!-- Textos -->
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Relatório de Fornecedores Cadastrados" Foreground="#111827" FontWeight="Bold" FontSize="15"/>
                                <TextBlock Text="Lista completa com certificações e status de operação." Foreground="#6B7280" FontSize="13" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <!-- OPÇÃO 3: PEÇAS -->
                    <RadioButton GroupName="RelatorioGroup" Checked="RadioButton_Checked" Tag="Pecas" Style="{StaticResource ReportOptionCardStyle}">
                        <StackPanel Orientation="Horizontal">
                            <!-- Ícone -->
                            <Border Width="44" Height="44" CornerRadius="10" Background="#FFF7ED" Margin="0,0,16,0">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="20" Foreground="#C2410C" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <!-- Textos -->
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Relatório de Componentes e Peças" Foreground="#111827" FontWeight="Bold" FontSize="15"/>
                                <TextBlock Text="Inventário detalhado com vinculação ao chassi (Ledger)." Foreground="#6B7280" FontSize="13" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <Separator Margin="0,10,0,24" Background="#E5E5EA"/>

                    <!-- BOTÃO GERAR RELATÓRIO -->
                    <Button Command="{Binding Relatorios.GerarRelatorioPdfCommand}" HorizontalAlignment="Left" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bgBorder" Background="#0A5B43" CornerRadius="8" Padding="28,14">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE896;" FontSize="18" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Gerar e Baixar PDF" Foreground="White" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bgBorder" Property="Background" Value="#1B7055"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>